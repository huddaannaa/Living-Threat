# Web
PORT=8970
DEBUG=true

# Elasticsearch
ES_URL=h
ES_INDEX=
ES_USER=elastic
ES_PASS=

# set false if you use self-signed certs (or provide ES_CA_CERTS path)
ES_VERIFY_CERTS=true
# ES_CA_CERTS=/path/to/ca.crt

# How many docs to load into the UI (client-side filtering happens in the browser)
BOOTSTRAP_SIZE=2000

# UI "now" mode:
# - latest  => uses newest doc Timestamp (+1 day) so your range slider still shows data
# - utc     => uses real current UTC time
#UI_NOW_MODE=latest
UI_NOW_LATEST_OFFSET_DAYS=2000

# Optional hard override (if set, it wins)
# UI_NOW_FIXED=2025-02-10T00:00:00Z
UI_NOW_FIXED=




UI_NOW_MODE=utc
UI_NOW_FIXED=
